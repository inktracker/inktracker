#!/bin/bash
# macOS PDF Service hook for the Biota film-output driver.
#
# When installed (symlinked into ~/Library/PDF Services/), this appears in
# the Print dialog's PDF dropdown as "Film Seps". macOS runs this script
# with the printed PDF as an argument — we delegate to the shared worker.
#
# Argv contract (from CUPS/macOS PDF Service):
#   $1 = document title (or job name)
#   $2 = printing options
#   $3 = path to the generated PDF (the important one)
#   $4 = (optional) root path
#
# Older macOS versions only pass 2 args (title + path). We defensively
# pick the last arg that looks like a .pdf path.

set -euo pipefail

# Locate our install dir via the env file written by install.sh.
# We can't use $0 reliably because this file is usually invoked via a
# symlink in ~/Library/PDF Services/.
env_file="$HOME/.config/biota-film-driver/env.sh"
if [[ -f "$env_file" ]]; then
  # shellcheck disable=SC1090
  source "$env_file"
fi
: "${INSTALL_DIR:=$HOME/Downloads/inktracker/seps-plugin/installable/print-driver}"
HERE="$INSTALL_DIR"

pdf=""
for arg in "$@"; do
  case "$arg" in
    *.pdf|*.PDF) pdf="$arg" ;;
  esac
done
doc_title="${1:-untitled}"

if [[ -z "$pdf" ]] || [[ ! -f "$pdf" ]]; then
  osascript -e 'display alert "Film Seps" message "No PDF was received from the print dialog." as critical'
  exit 1
fi

exec "$HERE/process-art.sh" "$pdf" "$doc_title"
